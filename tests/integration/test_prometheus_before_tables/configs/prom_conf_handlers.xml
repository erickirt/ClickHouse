<clickhouse>
    <http_port>8123</http_port>
    <tcp_port>9000</tcp_port>

    <prometheus>
        <port>8001</port>

        <handlers>
            <metrics_rule>
                <url>/metrics</url>
                <handler>
                    <type>metrics</type>
                    <metrics>true</metrics>
                    <events>true</events>
                    <asynchronous_metrics>true</asynchronous_metrics>
                </handler>
            </metrics_rule>
        </handlers>
    </prometheus>
</clickhouse>
