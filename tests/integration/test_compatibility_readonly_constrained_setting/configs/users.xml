<clickhouse>
    <!--
        Reproduces the recommended lockdown of `s3_allow_server_credentials_in_user_queries`: pin it to 0
        with an explicit value and a `readonly` (CONST) constraint, so untrusted users cannot enable it.

        A native-protocol client that sets an older `compatibility` resolves it on its own side and then
        transmits the reverted value of the pinned setting as an explicit change. The server must keep the
        pinned value instead of failing every query with SETTING_CONSTRAINT_VIOLATION.
    -->
    <profiles>
        <default>
            <s3_allow_server_credentials_in_user_queries>0</s3_allow_server_credentials_in_user_queries>
            <constraints>
                <s3_allow_server_credentials_in_user_queries>
                    <readonly/>
                </s3_allow_server_credentials_in_user_queries>
            </constraints>
        </default>
    </profiles>

    <users>
        <default>
            <password></password>
            <profile>default</profile>
            <access_management>1</access_management>
        </default>
    </users>
</clickhouse>
